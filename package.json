{
  "name": "knob",
  "version": "1.0.0",
  "description": "A polished Windows audio + display control panel that lives in the tray and is summoned by a global hotkey.",
  "author": "captkernel",
  "license": "MIT",
  "homepage": "https://github.com/captkernel/knob#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/captkernel/knob.git"
  },
  "bugs": {
    "url": "https://github.com/captkernel/knob/issues"
  },
  "keywords": [
    "audio",
    "windows",
    "electron",
    "tray",
    "default-device",
    "sound",
    "volume",
    "hotkey"
  ],
  "main": "./out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node scripts/download-helpers.mjs && node scripts/gen-icons.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:publish": "npm run build && electron-builder --publish always",
    "package:standalone": "powershell -ExecutionPolicy Bypass -File scripts/package-standalone.ps1",
    "dist:standalone": "npm run build && npm run package:standalone",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.462.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
